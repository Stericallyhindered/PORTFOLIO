  <XDFFLAG uniqueid="0x36A">
    <title>Send ID+2</title>
    <description>Send data as CAN SWITCH BOARDV3 Standart&#013;&#010;&#013;&#010;Byte0- Gear Target&#013;&#010;Byte1- Oil Temp, (Ofset -40)&#013;&#010;Byte2- Program SW.&#013;&#010;Byte3- ERROR CODE&#013;&#010;&#013;&#010;Flag:&#013;&#010;Byte4.0- Torque reduction when shifting gears&#013;&#010;Byte4.1- Safety mode activation&#013;&#010;Byte4.2- Parking&#013;&#010;Byte4.3- Oil cooler fan&#013;&#010;Byte4.4- T-Brake Activation&#013;&#010;Byte4.5- Brakeselenoid ON&#013;&#010;Byte4.6- Neutral&#013;&#010;Byte4.7- Blip&#013;&#010;Flag:&#013;&#010;Byte5.0- Automatic Mode&#013;&#010;Byte5.1- Adaptation activation &#013;&#010;Byte5.2- Hand Brake&#013;&#010;Byte5.3- Footbrake&#013;&#010;Byte5.4- Line Lock&#013;&#010;&#013;&#010;Byte6 -Wehicle SPEED  &#013;&#010;</description>
    <CATEGORYMEM index="0" category="38" />
    <CATEGORYMEM index="1" category="44" />
    <CATEGORYMEM index="2" category="39" />
    <EMBEDDEDDATA mmedaddress="0x6F0" mmedelementsizebits="8" mmedmajorstridebits="0" mmedminorstridebits="0" />
    <mask>0x08</mask>
  </XDFFLAG>
