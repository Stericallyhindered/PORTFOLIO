{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://grannasracing.com/schemas/gear-mapping-preset.json",
  "title": "GearMappingPreset",
  "type": "object",
  "required": ["id", "name", "inputCount", "outputCount", "matchTolerancePct", "gears"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "inputCount": { "type": "integer", "minimum": 1, "maximum": 3 },
    "outputCount": { "type": "integer", "minimum": 1, "maximum": 3 },
    "matchTolerancePct": { "type": "number", "minimum": 0.1, "maximum": 10 },
    "gears": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": { "$ref": "#/$defs/gearRow" }
    }
  },
  "$defs": {
    "pwmChannel": {
      "type": "object",
      "required": ["dutyPct", "periodMs", "vavg", "vrms", "vmax", "vmin"],
      "properties": {
        "dutyPct": { "type": "number", "minimum": 0, "maximum": 100 },
        "periodMs": { "type": "number", "minimum": 0.1, "maximum": 100 },
        "vavg": { "type": "number", "minimum": 0, "maximum": 12 },
        "vrms": { "type": "number", "minimum": 0, "maximum": 12 },
        "vmax": { "type": "number", "minimum": 0, "maximum": 12 },
        "vmin": { "type": "number", "minimum": 0, "maximum": 12 }
      }
    },
    "gearRow": {
      "type": "object",
      "required": ["gear", "inputs", "outputs"],
      "properties": {
        "gear": {
          "type": "string",
          "enum": ["Neutral", "1st", "2nd", "3rd", "4th", "5th", "6th", "Reverse"]
        },
        "inputs": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/pwmChannel" }
        },
        "outputs": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "$ref": "#/$defs/pwmChannel" }
        }
      }
    }
  }
}
