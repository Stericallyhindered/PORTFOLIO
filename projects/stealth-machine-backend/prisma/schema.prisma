// =============================================================================
// SMT Platform - Prisma Schema
// =============================================================================
// Database: Neon PostgreSQL (Serverless)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// =============================================================================
// USERS & AUTHENTICATION
// =============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole  @default(CUSTOMER)
  employeeId    String?   // For employees only
  phone         String?
  company       String?
  jobTitle      String?
  profileImage  String?   // Vercel Blob URL
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  // Relations
  machines          Machine[]
  tickets           SupportTicket[]       @relation("UserTickets")
  assignedTickets   SupportTicket[]       @relation("AssignedTickets")
  chatMessages      ChatMessage[]
  chatSessions      ChatSession[]         @relation("CustomerChatSessions")
  trainingProgress  TrainingProgress[]
  ticketMessages    TicketMessage[]
  auditLogs         AuditLog[]
  sessions          Session[]

  @@index([email])
  @@index([role])
}

enum UserRole {
  CUSTOMER      // Regular app users
  EMPLOYEE      // SMT employees - can handle tickets
  ADMIN         // Can manage content, users
  SUPER_ADMIN   // Full access including settings
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  userAgent    String?
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// =============================================================================
// MACHINES
// =============================================================================

model Machine {
  id             String        @id @default(cuid())
  userId         String
  model          String        // e.g., "SS3015CP"
  serialNumber   String        @unique
  machineType    String        // References MachineType
  nickname       String?       // User's custom name
  status         MachineStatus @default(ACTIVE)
  purchaseDate   DateTime?
  warrantyExpiry DateTime?
  location       String?
  notes          String?       @db.Text
  specifications Json?         // Flexible specs storage
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tickets SupportTicket[]

  @@index([userId])
  @@index([serialNumber])
  @@index([model])
}

enum MachineStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  DECOMMISSIONED
}

// Machine types/models catalog (for dropdowns)
model MachineType {
  id           String   @id @default(cuid())
  modelCode    String   @unique // e.g., "SS3015CP"
  displayName  String   // e.g., "SS3015CP Nighthawk - Enclosed Platform"
  description  String?  @db.Text
  category     String   // e.g., "Fiber Laser", "Press Brake"
  imageUrl     String?
  specifications Json?   // Default specs for this model
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// =============================================================================
// SUPPORT MATERIALS (Videos, PDFs, Images, etc.)
// =============================================================================

model SupportMaterial {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  category     String   // e.g., "manuals", "videos", "schematics"
  fileType     String   // "pdf", "video", "image", "document"
  fileUrl      String   // Vercel Blob URL
  fileName     String   // Original filename
  fileSize     Int?     // Size in bytes
  thumbnailUrl String?  // For videos/images
  machineModel String?  // Associated machine model (optional)
  tags         String[] // Searchable tags
  isPublished  Boolean  @default(true)
  sortOrder    Int      @default(0)
  viewCount    Int      @default(0)
  downloadCount Int     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String   // User ID who uploaded

  @@index([category])
  @@index([machineModel])
  @@index([isPublished])
  @@index([title])
}

model MaterialCategory {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "manuals"
  displayName String   // e.g., "Manuals & Guides"
  description String?
  icon        String?  // Icon name or URL
  color       String?  // Hex color
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =============================================================================
// AI CONFIGURATION
// =============================================================================

model AIConfig {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., "model", "max_tokens", "temperature"
  value       String   @db.Text
  type        String   // "string", "number", "boolean", "json"
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String   // User ID
}

model AIPrompt {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "main_system", "troubleshooting", "safety"
  displayName String   // e.g., "Main System Prompt"
  prompt      String   @db.Text
  description String?  @db.Text
  variables   String[] // e.g., ["materials", "machine_model"]
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String   // User ID

  @@index([name])
}

// Product catalog for AI knowledge
model Product {
  id           String   @id @default(cuid())
  modelCode    String   @unique // e.g., "SS3015CP"
  displayName  String   // e.g., "SS3015CP Nighthawk"
  description  String?  @db.Text
  category     String   // e.g., "Fiber Laser"
  keywords     String[] // Search keywords for AI
  specifications Json?   // Technical specs
  features     String[] // Feature list
  relatedMaterials String[] // Material IDs
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// Component catalog (BLT heads, CypCut, etc.)
model Component {
  id           String   @id @default(cuid())
  name         String   @unique // e.g., "BLT310"
  displayName  String   // e.g., "BLT310 Laser Head"
  description  String?  @db.Text
  category     String   // e.g., "Laser Head", "Software", "Valve"
  keywords     String[] // Search keywords
  manufacturer String?
  specifications Json?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// AI recognition patterns/keywords
model AIKeyword {
  id          String   @id @default(cuid())
  pattern     String   // Regex pattern or keyword
  type        String   // "product", "component", "technical", "action"
  matchesTo   String?  // What it maps to (product ID, etc.)
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
}

// =============================================================================
// SUPPORT TICKETS
// =============================================================================

model SupportTicket {
  id          String         @id @default(cuid())
  ticketNumber String        @unique @default(cuid()) // Human-readable number
  userId      String
  machineId   String?
  title       String
  description String         @db.Text
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  category    String         // e.g., "Technical", "Installation"
  assignedToId String?
  resolution  String?        @db.Text
  internalNotes String?      @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  resolvedAt  DateTime?
  closedAt    DateTime?

  // Relations
  user       User            @relation("UserTickets", fields: [userId], references: [id])
  assignedTo User?           @relation("AssignedTickets", fields: [assignedToId], references: [id])
  machine    Machine?        @relation(fields: [machineId], references: [id])
  messages   TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  WAITING_PARTS
  RESOLVED
  CLOSED
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  message   String   @db.Text
  isInternal Boolean @default(false) // Internal notes not visible to customer
  attachments String[] // File URLs
  createdAt DateTime @default(now())

  // Relations
  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

model TicketCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =============================================================================
// AI CHAT
// =============================================================================

model ChatMessage {
  id            String   @id @default(cuid())
  userId        String?  // Optional - null for anonymous users
  sessionId     String   // Groups messages in a conversation (UUID)
  chatSessionId String?  // Optional - links to ChatSession for customer tracking
  role          String   // "user", "assistant", "system"
  content       String   @db.Text
  metadata      Json?    // Referenced materials, tokens used, etc.
  createdAt     DateTime @default(now())

  // Relations
  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatSession ChatSession? @relation(fields: [chatSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
  @@index([chatSessionId])
  @@index([createdAt])
}

model ChatSession {
  id             String   @id @default(cuid())
  sessionId      String   @unique // UUID from chat - groups messages
  customerId     String?  // Links to User when identified
  customerName   String?
  customerEmail  String?
  customerPhone  String?
  machineModel   String?
  serialNumber   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  customer User?         @relation("CustomerChatSessions", fields: [customerId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([customerId])
  @@index([sessionId])
  @@index([createdAt])
}

// =============================================================================
// TRAINING
// =============================================================================

model TrainingModule {
  id            String   @id @default(cuid())
  title         String
  description   String   @db.Text
  content       String   @db.Text // Rich text/HTML content
  machineModel  String?  // Associated machine (optional)
  difficulty    String   // "beginner", "intermediate", "advanced"
  durationMins  Int      // Estimated duration
  prerequisites String[] // IDs of prerequisite modules
  objectives    String[] // Learning objectives
  videoUrl      String?  // Main video if any
  attachments   String[] // Additional material URLs
  quizQuestions Json?    // Quiz data
  isPublished   Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String

  // Relations
  progress TrainingProgress[]

  @@index([machineModel])
  @@index([isPublished])
}

model TrainingProgress {
  id          String    @id @default(cuid())
  userId      String
  moduleId    String
  status      String    @default("not_started") // "not_started", "in_progress", "completed"
  progress    Int       @default(0) // Percentage 0-100
  quizScore   Int?      // If quiz taken
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  // Relations
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
}

// =============================================================================
// APP SETTINGS & CONFIGURATION
// =============================================================================

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  type        String   // "string", "number", "boolean", "json", "color"
  category    String   // "branding", "features", "notifications", "security"
  displayName String
  description String?
  isPublic    Boolean  @default(false) // Can be fetched by Flutter app
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

// =============================================================================
// ANALYTICS & AUDIT
// =============================================================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // "create", "update", "delete", "login", etc.
  entityType  String   // "user", "material", "ticket", etc.
  entityId    String?
  details     Json?    // Additional details
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventType String   // "page_view", "material_view", "ai_chat", etc.
  eventData Json?
  sessionId String?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
}

// =============================================================================
// ANNOUNCEMENTS & NOTIFICATIONS
// =============================================================================

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  type        String    @default("info") // "info", "warning", "success", "error"
  targetRoles String[]  // Which roles see this
  isActive    Boolean   @default(true)
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String

  @@index([isActive])
  @@index([startsAt])
}
