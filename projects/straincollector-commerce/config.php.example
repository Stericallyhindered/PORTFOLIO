// Your Stripe Webhook Secret (starts with whsec_)
// Get this from: Stripe Dashboard → Developers → Webhooks → Your endpoint → Signing secret
define('STRIPE_WEBHOOK_SECRET', 'whsec_YOUR_WEBHOOK_SECRET_HERE');

