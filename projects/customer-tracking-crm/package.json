{
  "name": "customer-tracking-system",
  "version": "1.0.0",
  "description": "Full-featured customer tracking system with admin approval workflow",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run build:frontend && npm run build:customer-portal",
    "build:frontend": "cd frontend && npm run build",
    "build:customer-portal": "cd customer-portal && npm run build",
    "install:all": "npm install && cd frontend && npm install && cd ../customer-portal && npm install",
    "setup": "node setup.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.6",
    "tesseract.js": "^4.1.1",
    "nodemailer": "^6.9.7",
    "twilio": "^4.19.0",
    "sqlite3": "^5.1.6",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.1",
    "moment": "^2.29.4",
    "axios": "^1.6.2",
    "pdf-parse": "^1.1.1",
    "jimp": "^0.22.10"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": ["customer-tracking", "order-management", "crm", "admin-portal"],
  "author": "Customer Tracking System",
  "license": "MIT"
}
